---
import { Image } from 'astro:assets';
import logoDarkHorizontal from '../assets/brand/logo-dark-horizontal.png';
import Search from './Search.astro';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/insights', label: 'Insights' },
  { href: '/contact', label: 'Contact' },
];

const secondaryLinks = [
  { href: 'https://www.linkedin.com/in/akarmi', label: 'LinkedIn', external: true },
  { href: 'mailto:info@ahmadkarmi.com', label: 'Email', external: false },
];

const availabilityLine = 'Open for select projects';
const ctaSupport = 'Product, strategy, and growth work.';

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-background/80 backdrop-blur-sm md:backdrop-blur-md border-b border-border">
  <div class="container-custom">
    <nav class="flex items-center justify-between h-16 md:h-20">
      <!-- Logo -->
      <a 
        href="/" 
        class="flex items-center gap-2 hover:opacity-80 transition-opacity touch-manipulation"
        data-nav-prefetch
      >
        <Image 
          src={logoDarkHorizontal}
          alt="Ahmad Karmi" 
          width={308}
          height={112}
          loading="eager"
          fetchpriority="high"
          class="h-8 md:h-10 w-auto"
        />
      </a>

      <!-- Desktop Navigation -->
      <ul class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <li>
            <a 
              href={link.href}
              data-nav-prefetch
              class:list={[
                'text-sm font-medium transition-colors link-underline touch-manipulation',
                currentPath === link.href 
                  ? 'text-accent' 
                  : 'text-foreground-secondary hover:text-foreground'
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Right Side Actions -->
      <div class="flex items-center gap-2">
        <!-- Search Button -->
        <Search />
        
        <!-- CTA Button -->
        <a 
          href="/contact" 
          class="hidden md:inline-flex btn-secondary text-sm touch-manipulation"
          data-nav-prefetch
        >
          Get in Touch
        </a>

        <button
          id="mobile-menu-trigger"
          type="button"
          class="inline-flex md:hidden items-center justify-center rounded-full border border-border/60 bg-background/75 p-2.5 text-foreground-secondary transition-all hover:border-border hover:bg-background hover:text-foreground"
          aria-label="Open menu"
          aria-controls="mobile-menu-panel"
          aria-expanded="false"
        >
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 7h16M4 12h16M4 17h16" />
          </svg>
        </button>
      </div>
    </nav>
  </div>
</header>

<div id="mobile-menu" class="fixed inset-0 z-[120] hidden pointer-events-none md:hidden" aria-hidden="true">
  <button
    id="mobile-menu-backdrop"
    type="button"
    class="absolute inset-0 bg-foreground/70 opacity-0 backdrop-blur-md transition-opacity duration-300"
    aria-label="Close menu"
    tabindex="-1"
  ></button>

  <div
    id="mobile-menu-panel"
    class="absolute inset-y-0 right-0 flex w-full max-w-sm translate-x-full flex-col border-l border-border bg-background/95 shadow-2xl transition-transform duration-300 ease-out backdrop-blur-xl"
    role="dialog"
    aria-modal="true"
    aria-label="Mobile navigation"
  >
    <div class="flex flex-1 flex-col overflow-y-auto px-5 pb-6 pt-5">
      <div class="rounded-[1.5rem] border border-border/60 bg-background-secondary/15 px-4 py-4">
        <div class="flex items-center justify-between gap-4">
          <a
            href="/"
            class="flex items-center gap-2 hover:opacity-80 transition-opacity touch-manipulation"
            data-nav-prefetch
            data-mobile-menu-close
          >
            <Image
              src={logoDarkHorizontal}
              alt="Ahmad Karmi"
              width={220}
              height={80}
              loading="eager"
              class="h-8 w-auto"
            />
          </a>

          <button
            id="mobile-menu-close"
            type="button"
            class="inline-flex items-center justify-center rounded-full border border-border/60 bg-background/70 p-2 text-foreground-secondary transition-all hover:border-border hover:bg-background hover:text-foreground"
            aria-label="Close menu"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <div class="mt-5 flex items-center justify-between gap-3 border-t border-border/60 pt-4">
          <p class="text-[0.68rem] font-medium uppercase tracking-[0.2em] text-accent/90">{availabilityLine}</p>
          <button
            id="mobile-menu-search"
            type="button"
            class="inline-flex items-center gap-2 rounded-full border border-border/60 px-3 py-1.5 text-[0.8125rem] font-medium text-foreground-secondary transition-colors hover:border-accent/30 hover:text-foreground"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <span>Search</span>
          </button>
        </div>
      </div>

      <div class="mt-6 flex-1">
        <div class="space-y-1.5">
          {navLinks.map(link => (
            <a
              href={link.href}
              data-nav-prefetch
              data-mobile-menu-close
              class:list={[
                'group flex items-center justify-between rounded-2xl px-3 py-2.5 transition-colors touch-manipulation',
                currentPath === link.href
                  ? 'bg-accent/[0.06] text-accent'
                  : 'text-foreground hover:bg-background-secondary/45'
              ]}
            >
              <span class="font-display text-[1.55rem] leading-none tracking-[-0.025em]">{link.label}</span>
              <span class:list={[
                'h-2 w-2 rounded-full transition-colors',
                currentPath === link.href ? 'bg-accent' : 'bg-border/90 group-hover:bg-foreground-muted'
              ]}></span>
            </a>
          ))}
        </div>
      </div>

      <div class="mt-6 rounded-[1.5rem] border border-border/60 bg-background-secondary/15 px-5 py-5 text-foreground">
        <p class="text-[0.68rem] font-medium uppercase tracking-[0.2em] text-accent/90">{availabilityLine}</p>
        <p class="mt-3 max-w-[18rem] text-[0.95rem] leading-relaxed text-foreground-secondary">{ctaSupport}</p>
        <a
          href="/contact"
          class="mt-5 inline-flex w-full items-center justify-center rounded-full border border-accent/20 bg-accent/10 px-4 py-2.5 text-sm font-medium text-accent transition-colors hover:border-accent/30 hover:bg-accent/15 touch-manipulation"
          data-nav-prefetch
          data-mobile-menu-close
        >
          Get in touch
        </a>

        <div class="mt-5 flex flex-wrap gap-2 border-t border-border/60 pt-4">
          {secondaryLinks.map(link => (
            <a
              href={link.href}
              target={link.external ? '_blank' : undefined}
              rel={link.external ? 'noreferrer' : undefined}
              class="inline-flex items-center rounded-full border border-border/60 px-3 py-1.5 text-xs font-medium text-foreground-secondary transition-colors hover:border-border hover:text-foreground"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    const win = window;
    const state = win.__mobileMenuState || (win.__mobileMenuState = {
      open: false,
      restoreOverflow: '',
      closeTimer: null,
    });

    function getEls() {
      const trigger = document.getElementById('mobile-menu-trigger');
      const menu = document.getElementById('mobile-menu');
      const backdrop = document.getElementById('mobile-menu-backdrop');
      const panel = document.getElementById('mobile-menu-panel');
      const closeBtn = document.getElementById('mobile-menu-close');
      const searchBtn = document.getElementById('mobile-menu-search');
      const closers = document.querySelectorAll('[data-mobile-menu-close]');

      return { trigger, menu, backdrop, panel, closeBtn, searchBtn, closers };
    }

    function syncTrigger(expanded) {
      const { trigger } = getEls();
      if (trigger) {
        trigger.setAttribute('aria-expanded', expanded ? 'true' : 'false');
      }
    }

    function resetMenu() {
      const { menu, backdrop, panel } = getEls();
      if (!menu || !backdrop || !panel) return;

      if (state.closeTimer) {
        clearTimeout(state.closeTimer);
        state.closeTimer = null;
      }

      state.open = false;
      menu.classList.add('hidden', 'pointer-events-none');
      menu.classList.remove('pointer-events-auto');
      menu.setAttribute('aria-hidden', 'true');
      backdrop.classList.remove('opacity-100');
      backdrop.classList.add('opacity-0');
      panel.classList.remove('translate-x-0');
      panel.classList.add('translate-x-full');
      document.body.style.overflow = '';
      syncTrigger(false);
    }

    function openMenu() {
      const { menu, backdrop, panel, closeBtn } = getEls();
      if (!menu || !backdrop || !panel || state.open) return;

      if (state.closeTimer) {
        clearTimeout(state.closeTimer);
        state.closeTimer = null;
      }

      state.restoreOverflow = document.body.style.overflow;
      state.open = true;
      menu.classList.remove('hidden', 'pointer-events-none');
      menu.classList.add('pointer-events-auto');
      menu.setAttribute('aria-hidden', 'false');
      syncTrigger(true);
      document.body.style.overflow = 'hidden';

      requestAnimationFrame(() => {
        backdrop.classList.remove('opacity-0');
        backdrop.classList.add('opacity-100');
        panel.classList.remove('translate-x-full');
        panel.classList.add('translate-x-0');
      });

      window.setTimeout(() => {
        closeBtn?.focus();
      }, 150);
    }

    function closeMenu(restoreFocus = false) {
      const { trigger, menu, backdrop, panel } = getEls();
      if (!menu || !backdrop || !panel || !state.open) return;

      state.open = false;
      syncTrigger(false);
      backdrop.classList.remove('opacity-100');
      backdrop.classList.add('opacity-0');
      panel.classList.remove('translate-x-0');
      panel.classList.add('translate-x-full');
      document.body.style.overflow = state.restoreOverflow;

      if (state.closeTimer) {
        clearTimeout(state.closeTimer);
      }

      state.closeTimer = window.setTimeout(() => {
        menu.classList.add('hidden', 'pointer-events-none');
        menu.classList.remove('pointer-events-auto');
        menu.setAttribute('aria-hidden', 'true');
        state.closeTimer = null;
      }, 300);

      if (restoreFocus) {
        trigger?.focus();
      }
    }

    function openSearchFromMenu() {
      closeMenu();
      window.setTimeout(() => {
        const searchTrigger = document.getElementById('search-trigger');
        if (searchTrigger) {
          searchTrigger.click();
          return;
        }

        document.dispatchEvent(new KeyboardEvent('keydown', {
          key: 'k',
          ctrlKey: true,
          bubbles: true,
        }));
      }, 150);
    }

    function bindListeners() {
      const { trigger, backdrop, closeBtn, searchBtn, closers } = getEls();

      if (trigger && trigger.dataset.mobileMenuBound !== '1') {
        trigger.dataset.mobileMenuBound = '1';
        trigger.addEventListener('click', () => {
          if (state.open) {
            closeMenu(true);
          } else {
            openMenu();
          }
        });
      }

      if (backdrop && backdrop.dataset.mobileMenuBound !== '1') {
        backdrop.dataset.mobileMenuBound = '1';
        backdrop.addEventListener('click', () => closeMenu(true));
      }

      if (closeBtn && closeBtn.dataset.mobileMenuBound !== '1') {
        closeBtn.dataset.mobileMenuBound = '1';
        closeBtn.addEventListener('click', () => closeMenu(true));
      }

      if (searchBtn && searchBtn.dataset.mobileMenuBound !== '1') {
        searchBtn.dataset.mobileMenuBound = '1';
        searchBtn.addEventListener('click', openSearchFromMenu);
      }

      closers.forEach((el) => {
        if (el.dataset.mobileMenuBound === '1') return;
        el.dataset.mobileMenuBound = '1';
        el.addEventListener('click', () => closeMenu());
      });
    }

    if (!win.__mobileMenuKeydownBound) {
      win.__mobileMenuKeydownBound = true;
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && state.open) {
          closeMenu(true);
        }
      });
    }

    if (!win.__mobileMenuPageLoadBound) {
      win.__mobileMenuPageLoadBound = true;
      document.addEventListener('astro:page-load', () => {
        resetMenu();
        bindListeners();
      });
      window.addEventListener('pageshow', resetMenu);
    }

    resetMenu();
    bindListeners();
  })();
</script>
