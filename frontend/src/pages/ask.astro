---
import BaseLayout from '../layouts/BaseLayout.astro';
import AskHero from '../components/ask/AskHero';
---

<BaseLayout
  title="Ask K.AI"
  description="Ask K.AI anything about Ahmad's product work, AI projects, and writing. Trained on Ahmad's full corpus of insights and case studies."
  ogType="website"
  showHeader={false}
  showFooter={false}
>
  <main class="ask-page">
    <AskHero client:load />
  </main>
</BaseLayout>

<style is:global>
  /* /ask is the only page that uses the dark, immersive Gemini-style frame.
     Scoping these overrides to body:has(.ask-page) keeps the rest of the
     site's light theme untouched. */
  body:has(.ask-page) {
    background: #0a0a0c;
  }

  /* Faint dot grid — "graph paper" texture that reads as designed and
     technical, without color noise. Replaces the gradient blob backdrop. */
  .ask-glow {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background-image: radial-gradient(
      circle,
      rgba(255, 255, 255, 0.07) 1px,
      transparent 1px
    );
    background-size: 22px 22px;
  }
</style>
