---
import BaseLayout from '../layouts/BaseLayout.astro';
import AskHero from '../components/ask/AskHero';
---

<BaseLayout
  title="Ask K.AI"
  description="Ask K.AI anything about Ahmad's product work, AI projects, and writing. Trained on Ahmad's full corpus of insights and case studies."
  ogType="website"
  showHeader={false}
  showFooter={false}
>
  <main class="ask-page">
    <AskHero client:load />
  </main>
</BaseLayout>

<style is:global>
  /* /ask is the only page that uses the dark, immersive Gemini-style frame.
     Scoping these overrides to body:has(.ask-page) keeps the rest of the
     site's light theme untouched. */
  body:has(.ask-page) {
    background: #0a0a0c;
  }

  /* Two restrained, off-center accents. No pulsing, no spotlight — the
     type carries the page; the gradient is just atmospheric weight. */
  .ask-glow {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(
        ellipse 50% 45% at 20% 30%,
        rgba(59, 130, 246, 0.12) 0%,
        transparent 60%
      ),
      radial-gradient(
        ellipse 40% 35% at 85% 80%,
        rgba(99, 102, 241, 0.08) 0%,
        transparent 65%
      );
    filter: blur(60px);
  }

  /* Subtle vignette so the corners settle. */
  .ask-glow::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 80% 70% at 50% 50%,
      transparent 55%,
      rgba(0, 0, 0, 0.35) 100%
    );
  }
</style>
