---
import BaseLayout from '../layouts/BaseLayout.astro';
import AskHero from '../components/ask/AskHero';
---

<BaseLayout
  title="Ask K.AI"
  description="Ask K.AI anything about Ahmad's product work, AI projects, and writing. Trained on Ahmad's full corpus of insights and case studies."
  ogType="website"
  showHeader={false}
  showFooter={false}
>
  <main class="ask-page">
    <AskHero client:load />
  </main>
</BaseLayout>

<style is:global>
  /* /ask is the only page that uses the dark, immersive Gemini-style frame.
     Scoping these overrides to body:has(.ask-page) keeps the rest of the
     site's light theme untouched. */
  body:has(.ask-page) {
    background: #0a0a0c;
  }

  /* The pulsating radial glow behind the input. Pure CSS, no JS. */
  .ask-glow {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(
        ellipse 60% 50% at 50% 55%,
        rgba(59, 130, 246, 0.35) 0%,
        rgba(59, 130, 246, 0.18) 25%,
        rgba(30, 64, 175, 0.08) 50%,
        transparent 75%
      );
    filter: blur(40px);
    transform-origin: 50% 55%;
    animation: ask-glow-pulse 8s ease-in-out infinite;
    will-change: transform, opacity;
  }

  @keyframes ask-glow-pulse {
    0%, 100% {
      transform: scale(1);
      opacity: 0.85;
    }
    50% {
      transform: scale(1.08);
      opacity: 1;
    }
  }

  /* A subtle deeper-blue spot under the center, slightly out of phase so the
     pulse feels organic rather than mechanical. */
  .ask-glow::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 30% 25% at 50% 55%,
      rgba(99, 102, 241, 0.25) 0%,
      transparent 70%
    );
    filter: blur(30px);
    animation: ask-glow-pulse 8s ease-in-out infinite;
    animation-delay: -3s;
    opacity: 0.8;
  }

  /* Respect reduced motion. */
  @media (prefers-reduced-motion: reduce) {
    .ask-glow,
    .ask-glow::after {
      animation: none;
    }
  }
</style>
