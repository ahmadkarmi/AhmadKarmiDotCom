# WordPress API URL
PUBLIC_WP_URL=https://admin.ahmadkarmi.com
WP_USER=your_wp_username
WP_APP_PASSWORD=your_wp_app_password

# Ask Ahmad feature flag (build-time, public — controls whether the chat
# widget is rendered into the static HTML at all).
# Production: leave unset or set to "false". Preview/dev: set to "true".
PUBLIC_ASK_AHMAD_ENABLED=false

# Listen feature flag (build-time, public — controls whether the
# "Listen to this article" pill / sticky audio player is rendered on
# insight pages). Default off until pre-generated audio is wired up.
PUBLIC_LISTEN_ENABLED=false
