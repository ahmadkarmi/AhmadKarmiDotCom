# Ask Ahmad — server-side environment.
# These power the /api/ask-ahmad function, the ingestion script, and the eval runner.
# All values below are PLACEHOLDERS — overwrite locally in .env (gitignored) or set
# them in Vercel project settings per environment (Development / Preview / Production).

# Feature flag (runtime, server-side). Defaults to disabled.
# Set to "true" in Vercel for Preview + Development; leave unset/false in Production
# until launch.
ASK_AHMAD_ENABLED=false

# WordPress source for ingestion (read-only). Same as PUBLIC_WP_URL on the frontend.
PUBLIC_WP_URL=https://admin.ahmadkarmi.com

# Anthropic — Claude Sonnet 4.6 default chat, Haiku 4.5 eval judge.
# IMPORTANT: use a separate dev API key with a $20/mo hard cap in the Anthropic
# dashboard before any iteration. Production uses a different key with a $100/mo cap.
ANTHROPIC_API_KEY=sk-ant-...

# Voyage embeddings (text-embedding via voyageai npm pkg). $0.18/M tokens.
# Alternative: OPENAI_API_KEY with text-embedding-3-large.
VOYAGE_API_KEY=pa-...

# Neon Postgres + pgvector. Auto-provisioned by the Vercel Marketplace integration
# once you install Neon into the project — DO NOT set this manually if you used the
# Marketplace install.
DATABASE_URL=postgresql://...

# Upstash Redis (rate limiting + credit ledger). Auto-provisioned by the Vercel
# Marketplace integration — DO NOT set manually if you used the Marketplace install.
KV_REST_API_URL=https://...upstash.io
KV_REST_API_TOKEN=...
